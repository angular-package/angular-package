{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "es2015",
    "module": "es2020",
    "lib": [
      "es2018",
      "dom"
    ],
    "paths": {
      "spectre": [
        "dist/spectre/spectre",
        "dist/spectre"
      ],
      "change-detection": [
        "dist/change-detection/change-detection",
        "dist/change-detection"
      ],
      "core": [
        "dist/core/core",
        "dist/core"
      ]
    }
  }
}